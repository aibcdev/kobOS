generator client {
  provider      = "prisma-client-js"
  // Netlify / AWS-style Linux runtimes (local stays "native")
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["public"]
}

enum Role {
  OWNER
  ADMIN
  MEMBER
  @@schema("public")
}

enum SubscriptionPlan {
  FREE
  STARTER
  PRO
  @@schema("public")
}

enum InsightType {
  SEO_OPPORTUNITY
  TRAFFIC_DROP
  CAMPAIGN_IDEA
  SLOW_DAY_ALERT
  TREND_ALERT
  MENU_PERFORMANCE
  LOCAL_SEARCH_GAP
  COMPETITOR_WARNING
  @@schema("public")
}

enum InsightPriority {
  LOW
  MEDIUM
  HIGH
  @@schema("public")
}

enum InsightStatus {
  OPEN
  DISMISSED
  DONE
  @@schema("public")
}

enum RecommendationType {
  CREATE_BLOG
  CREATE_CAMPAIGN
  UPDATE_HOMEPAGE
  RUN_PROMOTION
  GENERATE_SEO_PAGE
  SEND_EMAIL
  POST_SOCIAL
  OPTIMIZE_MENU
  @@schema("public")
}

enum ContentType {
  SEO_BLOG
  LOCATION_PAGE
  MENU_DESCRIPTIONS
  EVENT_PAGE
  EMAIL_CAMPAIGN
  INSTAGRAM_CAPTION
  TIKTOK_CONCEPT
  GOOGLE_BUSINESS_POST
  GROWTH_FOOD_ANALYSIS
  GROWTH_WEBSITE_PLAN
  GROWTH_REVIEW_REPLY
  CREATIVE_BRAND_BRIEF
  CREATIVE_UGC
  CREATIVE_DISH
  @@schema("public")
}

enum CreativePackStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  @@schema("public")
}

enum ServiceRequestType {
  WEBSITE
  LOGO
  SEO_RESURFACE
  CREATIVE_PACK
  OTHER
  @@schema("public")
}

enum ServiceRequestStatus {
  REQUESTED
  IN_PROGRESS
  DELIVERED
  CANCELLED
  @@schema("public")
}

enum CreditLedgerReason {
  MONTHLY_GRANT
  SERVICE_REQUEST
  MANUAL_ADJUST
  REFUND
  @@schema("public")
}

enum ContentStatus {
  DRAFT
  READY
  FAILED
  @@schema("public")
}

enum CampaignType {
  PROMOTIONAL
  ENGAGEMENT
  SEO_PUSH
  @@schema("public")
}

enum CampaignChannel {
  EMAIL
  SMS
  INSTAGRAM
  FACEBOOK
  GOOGLE_POST
  WEBSITE_BANNER
  @@schema("public")
}

enum CampaignLifecycle {
  DRAFT
  SCHEDULED
  ACTIVE
  PAUSED
  COMPLETED
  @@schema("public")
}

enum IntegrationProvider {
  GOOGLE_ANALYTICS
  GOOGLE_SEARCH_CONSOLE
  GOOGLE_CALENDAR
  GMAIL
  INSTAGRAM
  TIKTOK
  OPENTABLE
  RESY
  TOAST
  SQUARE
  SHOPIFY
  @@schema("public")
}

enum WebsiteEventType {
  CLICK
  SCROLL_DEPTH
  BOUNCE
  CTA_CONVERT
  @@schema("public")
}

enum AssetType {
  FOOD_PHOTO
  VIDEO
  LOGO
  BRANDING
  WEBSITE_SCREENSHOT
  @@schema("public")
}

enum ReviewSource {
  GOOGLE
  YELP
  OTHER
  @@schema("public")
}

enum ReviewReplyStatus {
  DRAFT
  APPROVED
  POSTED
  @@schema("public")
}

enum AgentActionStatus {
  PENDING
  COMPLETED
  FAILED
  SKIPPED
  @@schema("public")
}

enum OutboundLeadStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  SENT
  CONTACTED
  RESPONDED
  CONVERTED
  ARCHIVED
  @@schema("public")
}

enum OutboundLeadSource {
  UK_COLD
  AUDIT
  MANUAL
  LEGACY
  LEAD_ENGINE
  @@schema("public")
}

enum LeadProspectStatus {
  DISCOVERED
  ANALYZED
  QUEUED
  ARCHIVED
  @@schema("public")
}

enum LeadBusinessType {
  RESTAURANT
  CAFE
  TAKEAWAY
  SMALL_GROUP
  @@schema("public")
}

enum AiPersonality {
  BALANCED
  WARM
  DIRECT
  CONCISE
  SASSY
  @@schema("public")
}

enum TaskSource {
  AUDIT
  AI
  ENGINE
  MANUAL
  @@schema("public")
}

enum TaskStatus {
  PENDING
  APPROVED
  DONE
  DISMISSED
  @@schema("public")
}

enum TaskCategory {
  REVIEWS
  SOCIAL
  SEO
  EMAIL
  HOLIDAY
  MENU
  COMPETITOR
  OPERATIONS
  CONTENT
  @@schema("public")
}

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
  @@schema("public")
}

enum SalesSnapshotSource {
  SQUARE
  TOAST
  MANUAL
  SAMPLE
  @@schema("public")
}

enum ReviewTheme {
  FOOD
  SERVICE
  PRICE
  SPEED
  ATMOSPHERE
  CLEANLINESS
  @@schema("public")
}

enum ReviewSentiment {
  POSITIVE
  NEGATIVE
  NEUTRAL
  @@schema("public")
}

model Organization {
  id           String       @id @default(cuid())
  name         String
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  restaurants  Restaurant[]
  @@schema("public")
}

model User {
  id          String       @id @db.Uuid
  email       String       @unique
  name        String?
  avatarUrl   String?
  role        Role         @default(OWNER)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  memberships TeamMember[]
  @@schema("public")
}

model TeamMember {
  id           String     @id @default(cuid())
  userId       String     @db.Uuid
  restaurantId String
  role         Role       @default(MEMBER)
  createdAt    DateTime   @default(now())
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, restaurantId])
  @@index([restaurantId])
  @@schema("public")
}

model Restaurant {
  id                 String            @id @default(cuid())
  organizationId     String?
  name               String
  slug               String            @unique
  cuisineType        String?
  city               String?
  state              String?
  timezone           String            @default("America/Chicago")
  website            String?
  logo               String?
  subscriptionPlan   SubscriptionPlan  @default(FREE)
  stripeCustomerId   String?
  stripeSubscriptionId String?
  /** Credits available for human-fulfilled service requests (website, logo, SEO, etc.). */
  creditBalance      Int               @default(0)
  creditsRefreshedAt DateTime?
  vibe               String?
  googleBusinessUrl  String?
  aiPersonality      AiPersonality     @default(BALANCED)
  useSampleData      Boolean           @default(false)
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  organization       Organization?     @relation(fields: [organizationId], references: [id])
  visibilityAudits   VisibilityAudit[]
  members            TeamMember[]
  integrations       Integration[]
  insights           GrowthInsight[]
  recommendations    Recommendation[]
  contents           GeneratedContent[]
  campaigns          Campaign[]
  keywords           Keyword[]
  websiteEvents      WebsiteEvent[]
  digestRuns         DigestRun[]
  dailyScans         DailyScan[]
  assets             Asset[]
  customerReviews    CustomerReview[]
  reviewerProfiles   ReviewerProfile[]
  agentActions       AgentAction[]
  outboundLeads      OutboundLead[]
  leadProspects      LeadProspect[]
  chiefOfStaffTasks  ChiefOfStaffTask[]
  dailyBriefSnapshots DailyBriefSnapshot[]
  conversations      Conversation[]
  salesSnapshots     SalesSnapshot[]
  socialSnapshots    SocialSnapshot[]
  workspaceAppPins   WorkspaceAppPin[]
  creativePacks      CreativePack[]
  serviceRequests    ServiceRequest[]
  creditLedger       CreditLedgerEntry[]

  @@index([organizationId])
  @@schema("public")
}

model Integration {
  id                     String              @id @default(cuid())
  restaurantId           String
  provider               IntegrationProvider
  encryptedAccessToken   String?
  encryptedRefreshToken  String?
  metadata               Json                @default("{}")
  connectedAt            DateTime            @default(now())
  updatedAt              DateTime            @updatedAt
  restaurant             Restaurant          @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@unique([restaurantId, provider])
  @@index([restaurantId])
  @@schema("public")
}

model GrowthInsight {
  id           String          @id @default(cuid())
  restaurantId String
  type         InsightType
  priority     InsightPriority @default(MEDIUM)
  title        String
  description  String
  data         Json            @default("{}")
  status       InsightStatus   @default(OPEN)
  createdAt    DateTime        @default(now())
  restaurant   Restaurant      @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  recommendations Recommendation[]

  @@index([restaurantId, status])
  @@index([createdAt])
  @@schema("public")
}

model Recommendation {
  id            String              @id @default(cuid())
  restaurantId  String
  insightId     String?
  type          RecommendationType
  title         String
  action        String
  aiSummary     String?
  impactScore   Int                 @default(50)
  createdAt     DateTime            @default(now())
  restaurant    Restaurant          @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  insight       GrowthInsight?       @relation(fields: [insightId], references: [id], onDelete: SetNull)

  @@index([restaurantId])
  @@index([insightId])
  @@schema("public")
}

model GeneratedContent {
  id             String        @id @default(cuid())
  restaurantId   String
  creativePackId String?
  type           ContentType
  prompt         String
  output         String        @default("")
  imageUrl       String?
  status         ContentStatus @default(DRAFT)
  published      Boolean       @default(false)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  restaurant     Restaurant    @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  creativePack   CreativePack? @relation(fields: [creativePackId], references: [id], onDelete: SetNull)

  @@index([restaurantId])
  @@index([creativePackId])
  @@schema("public")
}

/** One-click Creative Agent pack — brand brief + month of UGC / dish creatives. */
model CreativePack {
  id           String             @id @default(cuid())
  restaurantId String
  status       CreativePackStatus @default(PENDING)
  brief        Json               @default("{}")
  errorMessage String?
  targetCount  Int                @default(12)
  doneCount    Int                @default(0)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  restaurant   Restaurant         @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  contents     GeneratedContent[]

  @@index([restaurantId, createdAt])
  @@schema("public")
}

model Campaign {
  id           String             @id @default(cuid())
  restaurantId String
  type         CampaignType
  title        String
  channel      CampaignChannel
  status       CampaignLifecycle @default(DRAFT)
  scheduledAt  DateTime?
  payload      Json              @default("{}")
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  restaurant   Restaurant        @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@index([restaurantId, status])
  @@schema("public")
}

model Keyword {
  id               String      @id @default(cuid())
  restaurantId     String
  keyword          String
  ranking          Int?
  searchVolume     Int?
  opportunityScore Float?
  createdAt        DateTime    @default(now())
  restaurant       Restaurant  @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@index([restaurantId])
  @@schema("public")
}

model WebsiteEvent {
  id           String           @id @default(cuid())
  restaurantId String
  type         WebsiteEventType
  metadata     Json             @default("{}")
  createdAt    DateTime         @default(now())
  restaurant   Restaurant       @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@index([restaurantId])
  @@schema("public")
}

model DigestRun {
  id           String      @id @default(cuid())
  restaurantId String
  snapshot     Json       @default("{}")
  ranAt        DateTime   @default(now())
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@index([restaurantId, ranAt])
  @@schema("public")
}

model DemoRequest {
  id             String   @id @default(cuid())
  firstName      String
  lastName       String
  email          String
  restaurantName String
  addressLine1   String?
  city           String?
  postalCode     String?
  phone          String?
  message        String?
  createdAt      DateTime @default(now())

  @@index([createdAt])
  @@index([email])
  @@schema("public")
}

model DailyScan {
  id                String     @id @default(cuid())
  restaurantId      String
  scanDate          DateTime   @db.Date
  visibilityScore   Int?
  visualHealthScore Int?
  reviewHealthScore Int?
  briefingJson      Json       @default("{}")
  createdAt         DateTime   @default(now())
  restaurant        Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@unique([restaurantId, scanDate])
  @@index([restaurantId])
  @@schema("public")
}

model Asset {
  id           String     @id @default(cuid())
  restaurantId String
  type         AssetType
  url          String?
  metadata     Json       @default("{}")
  uploadedAt   DateTime   @default(now())
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@index([restaurantId, type])
  @@schema("public")
}

model CustomerReview {
  id                 String       @id @default(cuid())
  restaurantId      String
  source              ReviewSource
  externalReviewId    String?
  reviewerName        String?
  rating              Int
  body                String       @default("")
  reviewedAt          DateTime?
  replied             Boolean      @default(false)
  relationshipScore   Int          @default(0)
  restaurant          Restaurant   @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  replies             ReviewReply[]
  themeTags           ReviewThemeTag[]

  @@unique([source, externalReviewId])
  @@index([restaurantId, reviewedAt])
  @@schema("public")
}

model Conversation {
  id           String    @id @default(cuid())
  restaurantId String
  title        String    @default("New chat")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  messages     Message[]

  @@index([restaurantId, updatedAt])
  @@schema("public")
}

model Message {
  id             String      @id @default(cuid())
  conversationId String
  role           MessageRole
  content        String      @default("")
  toolCalls      Json?
  createdAt      DateTime    @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@schema("public")
}

model SalesSnapshot {
  id           String              @id @default(cuid())
  restaurantId String
  date         DateTime            @db.Date
  revenueCents Int                 @default(0)
  orderCount   Int                 @default(0)
  source       SalesSnapshotSource @default(MANUAL)
  createdAt    DateTime            @default(now())
  restaurant   Restaurant          @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@unique([restaurantId, date, source])
  @@index([restaurantId, date])
  @@schema("public")
}

model SocialSnapshot {
  id              String   @id @default(cuid())
  restaurantId    String
  date            DateTime @db.Date
  followers       Int      @default(0)
  postEngagements Int      @default(0)
  source          String   @default("INSTAGRAM")
  createdAt       DateTime @default(now())
  restaurant      Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@unique([restaurantId, date, source])
  @@index([restaurantId, date])
  @@schema("public")
}

model ReviewThemeTag {
  id        String          @id @default(cuid())
  reviewId  String
  theme     ReviewTheme
  sentiment ReviewSentiment
  review    CustomerReview  @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@unique([reviewId, theme])
  @@index([reviewId])
  @@schema("public")
}

model WorkspaceAppPin {
  id           String     @id @default(cuid())
  restaurantId String
  title        String
  description  String     @default("")
  href         String
  icon         String     @default("grid")
  createdAt    DateTime   @default(now())
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@index([restaurantId, createdAt])
  @@schema("public")
}

model ReviewReply {
  id        String            @id @default(cuid())
  reviewId  String
  replyText String            @default("")
  status    ReviewReplyStatus @default(DRAFT)
  postedAt  DateTime?
  review    CustomerReview    @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@index([reviewId])
  @@schema("public")
}

model ReviewerProfile {
  id             String     @id @default(cuid())
  restaurantId String
  name           String
  contactInfo    Json       @default("{}")
  notes          String?
  totalVisits    Int        @default(0)
  influenceScore Int        @default(0)
  lastContactAt  DateTime?
  restaurant     Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@index([restaurantId])
  @@schema("public")
}

model AgentAction {
  id            String            @id @default(cuid())
  restaurantId String
  actionType    String
  description   String
  status        AgentActionStatus @default(PENDING)
  createdAt     DateTime          @default(now())
  restaurant    Restaurant        @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@index([restaurantId, createdAt])
  @@schema("public")
}

enum OutboundEmailVariant {
  A
  B

  @@schema("public")
}

model OutboundLead {
  id                     String               @id @default(cuid())
  workspaceRestaurantId  String?
  placeId                String?
  city                   String?
  restaurantName         String?
  websiteUrl             String?
  contactEmail           String?
  insightSummary         String?
  messageSubject         String?
  messageBody            String?
  suggestedTone          String?
  status                 OutboundLeadStatus   @default(DRAFT)
  source                 OutboundLeadSource   @default(LEGACY)
  emailVariant           OutboundEmailVariant?
  visibilityAuditId      String?
  auditUrl               String?
  qualifyScore           Int?
  reviewCount            Int?
  enrichmentSource       String?
  createdAt              DateTime             @default(now())
  workspaceRestaurant    Restaurant?          @relation(fields: [workspaceRestaurantId], references: [id], onDelete: Cascade)
  leadProspect           LeadProspect?

  @@index([status, createdAt])
  @@index([workspaceRestaurantId, status, createdAt])
  @@index([workspaceRestaurantId, source, status])
  @@index([placeId])
  @@index([visibilityAuditId])
  @@index([emailVariant, status])
  @@schema("public")
}

/** Lead engine prospect pool — discovered via Agent A, scored by Agent B. */
model LeadProspect {
  id                     String             @id @default(cuid())
  workspaceRestaurantId  String
  canonicalKey           String
  placeId                String?
  name                   String
  city                   String
  country                String             @default("GB")
  formattedAddress       String?
  businessType           LeadBusinessType   @default(RESTAURANT)
  locationCount          Int?
  deliveryPlatforms      String[]           @default([])
  platformRank           Int?
  platformRankPercentile Float?
  platformRegion         String?
  platformMenuUrl        String?
  websiteUrl             String?
  contactEmail           String?
  contactPhone           String?
  hasContactForm         Boolean            @default(false)
  reviewCount            Int?
  rating                 Float?
  lastReviewAt           DateTime?
  googleBusinessClaimed  Boolean?
  instagramUrl           String?
  instagramFollowers     Int?
  instagramPostGapDays   Int?
  hasTikTok              Boolean            @default(false)
  facebookUrl            String?
  weakWebsite            Boolean            @default(false)
  websiteStale           Boolean            @default(false)
  websiteCopyrightYear   Int?
  weakPhotography        Boolean            @default(false)
  hasEmailCapture        Boolean            @default(false)
  pdfMenu                Boolean            @default(false)
  hasGoogleBusinessPosts Boolean            @default(false)
  hasTripadvisor         Boolean            @default(false)
  hasOnlineOrdering      Boolean            @default(false)
  kobOpportunityScore    Int?
  scoreBreakdown         Json               @default("{}")
  opportunities          String[]           @default([])
  disqualifiers          String[]           @default([])
  status                 LeadProspectStatus @default(DISCOVERED)
  outboundLeadId         String?            @unique
  visibilityAuditId      String?
  enrichmentSource       String?
  analyzedAt             DateTime?
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt
  workspaceRestaurant    Restaurant         @relation(fields: [workspaceRestaurantId], references: [id], onDelete: Cascade)
  outboundLead           OutboundLead?      @relation(fields: [outboundLeadId], references: [id], onDelete: SetNull)

  @@unique([workspaceRestaurantId, canonicalKey])
  @@index([workspaceRestaurantId, placeId])
  @@index([workspaceRestaurantId, status, kobOpportunityScore])
  @@index([status, createdAt])
  @@schema("public")
}

model StripeWebhookEvent {
  id        String   @id
  type      String
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@schema("public")
}

/** Public visibility audit (grader funnel); no auth required to create. */
model VisibilityAudit {
  id                String    @id @default(cuid())
  restaurantId      String?
  restaurant        Restaurant? @relation(fields: [restaurantId], references: [id], onDelete: SetNull)
  restaurantName    String
  city              String
  websiteUrl        String?
  /** Pretty public path segment: /audit/{slug} */
  slug              String?   @unique
  overallScore      Int
  seoScore          Int
  designScore       Int
  mobileScore       Int
  conversionScore   Int
  resultPayload     Json      @default("{}")
  leadEmail         String?
  leadPhone         String?
  leadCapturedAt    DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  siteScan          SiteScan?

  @@index([createdAt])
  @@index([restaurantId])
  @@schema("public")
}

/** Daily Chief of Staff brief + task queue for restaurant owners. */
model ChiefOfStaffTask {
  id                String        @id @default(cuid())
  restaurantId      String
  title             String
  detail            String        @default("")
  category          TaskCategory
  source            TaskSource
  status            TaskStatus    @default(PENDING)
  impactLabel       String?
  estimatedMinutes  Int           @default(5)
  confidenceScore   Int           @default(75)
  revenueLowGbp     Int?
  revenueHighGbp    Int?
  requiresIntegration String?
  draftPayload      Json?
  auditId           String?
  conversationId    String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  restaurant        Restaurant    @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@index([restaurantId, status, createdAt])
  @@schema("public")
}

model DailyBriefSnapshot {
  id           String     @id @default(cuid())
  restaurantId String
  briefDate    DateTime   @db.Date
  greeting     String
  summaryJson  Json       @default("{}")
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@unique([restaurantId, briefDate])
  @@index([restaurantId])
  @@schema("public")
}

model SiteScan {
  id                   String          @id @default(cuid())
  visibilityAuditId    String          @unique
  visibilityAudit      VisibilityAudit @relation(fields: [visibilityAuditId], references: [id], onDelete: Cascade)
  browserbaseSessionId String?
  screenshotUrls       Json            @default("[]")
  rawStagehandJson     Json?
  visualMetricsJson    Json?
  status               String          @default("completed")
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
  @@schema("public")
}

/** Owner-requested deliverable fulfilled manually by KOB (costs credits). */
model ServiceRequest {
  id            String               @id @default(cuid())
  restaurantId  String
  type          ServiceRequestType
  status        ServiceRequestStatus @default(REQUESTED)
  title         String
  notes         String               @default("")
  creditCost    Int
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  deliveredAt   DateTime?
  restaurant    Restaurant           @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@index([restaurantId, createdAt])
  @@index([status, createdAt])
  @@schema("public")
}

model CreditLedgerEntry {
  id           String             @id @default(cuid())
  restaurantId String
  delta        Int
  balanceAfter Int
  reason       CreditLedgerReason
  note         String             @default("")
  requestId    String?
  createdAt    DateTime           @default(now())
  restaurant   Restaurant         @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@index([restaurantId, createdAt])
  @@schema("public")
}
