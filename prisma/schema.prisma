generator client {
  provider      = "prisma-client-js"
  // Netlify / AWS-style Linux runtimes (local stays "native")
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["public"]
}

enum Role {
  OWNER
  ADMIN
  MEMBER
  @@schema("public")
}

enum SubscriptionPlan {
  FREE
  STARTER
  PRO
  @@schema("public")
}

enum InsightType {
  SEO_OPPORTUNITY
  TRAFFIC_DROP
  CAMPAIGN_IDEA
  SLOW_DAY_ALERT
  TREND_ALERT
  MENU_PERFORMANCE
  LOCAL_SEARCH_GAP
  COMPETITOR_WARNING
  @@schema("public")
}

enum InsightPriority {
  LOW
  MEDIUM
  HIGH
  @@schema("public")
}

enum InsightStatus {
  OPEN
  DISMISSED
  DONE
  @@schema("public")
}

enum RecommendationType {
  CREATE_BLOG
  CREATE_CAMPAIGN
  UPDATE_HOMEPAGE
  RUN_PROMOTION
  GENERATE_SEO_PAGE
  SEND_EMAIL
  POST_SOCIAL
  OPTIMIZE_MENU
  @@schema("public")
}

enum ContentType {
  SEO_BLOG
  LOCATION_PAGE
  MENU_DESCRIPTIONS
  EVENT_PAGE
  EMAIL_CAMPAIGN
  INSTAGRAM_CAPTION
  TIKTOK_CONCEPT
  GOOGLE_BUSINESS_POST
  GROWTH_FOOD_ANALYSIS
  GROWTH_WEBSITE_PLAN
  GROWTH_REVIEW_REPLY
  @@schema("public")
}

enum ContentStatus {
  DRAFT
  READY
  FAILED
  @@schema("public")
}

enum CampaignType {
  PROMOTIONAL
  ENGAGEMENT
  SEO_PUSH
  @@schema("public")
}

enum CampaignChannel {
  EMAIL
  SMS
  INSTAGRAM
  FACEBOOK
  GOOGLE_POST
  WEBSITE_BANNER
  @@schema("public")
}

enum CampaignLifecycle {
  DRAFT
  SCHEDULED
  ACTIVE
  PAUSED
  COMPLETED
  @@schema("public")
}

enum IntegrationProvider {
  GOOGLE_ANALYTICS
  GOOGLE_SEARCH_CONSOLE
  INSTAGRAM
  TIKTOK
  OPENTABLE
  RESY
  TOAST
  SQUARE
  SHOPIFY
  @@schema("public")
}

enum WebsiteEventType {
  CLICK
  SCROLL_DEPTH
  BOUNCE
  CTA_CONVERT
  @@schema("public")
}

enum AssetType {
  FOOD_PHOTO
  VIDEO
  LOGO
  BRANDING
  WEBSITE_SCREENSHOT
  @@schema("public")
}

enum ReviewSource {
  GOOGLE
  YELP
  OTHER
  @@schema("public")
}

enum ReviewReplyStatus {
  DRAFT
  APPROVED
  POSTED
  @@schema("public")
}

enum AgentActionStatus {
  PENDING
  COMPLETED
  FAILED
  SKIPPED
  @@schema("public")
}

enum OutboundLeadStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  SENT
  CONTACTED
  RESPONDED
  CONVERTED
  ARCHIVED
  @@schema("public")
}

enum OutboundLeadSource {
  UK_COLD
  AUDIT
  MANUAL
  LEGACY
  @@schema("public")
}

enum AiPersonality {
  BALANCED
  WARM
  DIRECT
  CONCISE
  SASSY
  @@schema("public")
}

enum TaskSource {
  AUDIT
  AI
  ENGINE
  MANUAL
  @@schema("public")
}

enum TaskStatus {
  PENDING
  APPROVED
  DONE
  DISMISSED
  @@schema("public")
}

enum TaskCategory {
  REVIEWS
  SOCIAL
  SEO
  EMAIL
  HOLIDAY
  MENU
  COMPETITOR
  OPERATIONS
  CONTENT
  @@schema("public")
}

model Organization {
  id           String       @id @default(cuid())
  name         String
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  restaurants  Restaurant[]
  @@schema("public")
}

model User {
  id          String       @id @db.Uuid
  email       String       @unique
  name        String?
  avatarUrl   String?
  role        Role         @default(OWNER)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  memberships TeamMember[]
  @@schema("public")
}

model TeamMember {
  id           String     @id @default(cuid())
  userId       String     @db.Uuid
  restaurantId String
  role         Role       @default(MEMBER)
  createdAt    DateTime   @default(now())
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, restaurantId])
  @@index([restaurantId])
  @@schema("public")
}

model Restaurant {
  id                 String            @id @default(cuid())
  organizationId     String?
  name               String
  slug               String            @unique
  cuisineType        String?
  city               String?
  state              String?
  timezone           String            @default("America/Chicago")
  website            String?
  logo               String?
  subscriptionPlan   SubscriptionPlan  @default(FREE)
  stripeCustomerId   String?
  stripeSubscriptionId String?
  vibe               String?
  googleBusinessUrl  String?
  aiPersonality      AiPersonality     @default(BALANCED)
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  organization       Organization?     @relation(fields: [organizationId], references: [id])
  visibilityAudits   VisibilityAudit[]
  members            TeamMember[]
  integrations       Integration[]
  insights           GrowthInsight[]
  recommendations    Recommendation[]
  contents           GeneratedContent[]
  campaigns          Campaign[]
  keywords           Keyword[]
  websiteEvents      WebsiteEvent[]
  digestRuns         DigestRun[]
  dailyScans         DailyScan[]
  assets             Asset[]
  customerReviews    CustomerReview[]
  reviewerProfiles   ReviewerProfile[]
  agentActions       AgentAction[]
  outboundLeads      OutboundLead[]
  chiefOfStaffTasks  ChiefOfStaffTask[]
  dailyBriefSnapshots DailyBriefSnapshot[]

  @@index([organizationId])
  @@schema("public")
}

model Integration {
  id                     String              @id @default(cuid())
  restaurantId           String
  provider               IntegrationProvider
  encryptedAccessToken   String?
  encryptedRefreshToken  String?
  metadata               Json                @default("{}")
  connectedAt            DateTime            @default(now())
  updatedAt              DateTime            @updatedAt
  restaurant             Restaurant          @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@unique([restaurantId, provider])
  @@index([restaurantId])
  @@schema("public")
}

model GrowthInsight {
  id           String          @id @default(cuid())
  restaurantId String
  type         InsightType
  priority     InsightPriority @default(MEDIUM)
  title        String
  description  String
  data         Json            @default("{}")
  status       InsightStatus   @default(OPEN)
  createdAt    DateTime        @default(now())
  restaurant   Restaurant      @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  recommendations Recommendation[]

  @@index([restaurantId, status])
  @@index([createdAt])
  @@schema("public")
}

model Recommendation {
  id            String              @id @default(cuid())
  restaurantId  String
  insightId     String?
  type          RecommendationType
  title         String
  action        String
  aiSummary     String?
  impactScore   Int                 @default(50)
  createdAt     DateTime            @default(now())
  restaurant    Restaurant          @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  insight       GrowthInsight?       @relation(fields: [insightId], references: [id], onDelete: SetNull)

  @@index([restaurantId])
  @@index([insightId])
  @@schema("public")
}

model GeneratedContent {
  id           String       @id @default(cuid())
  restaurantId String
  type         ContentType
  prompt       String
  output       String       @default("")
  status       ContentStatus @default(DRAFT)
  published    Boolean      @default(false)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  restaurant   Restaurant   @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@index([restaurantId])
  @@schema("public")
}

model Campaign {
  id           String             @id @default(cuid())
  restaurantId String
  type         CampaignType
  title        String
  channel      CampaignChannel
  status       CampaignLifecycle @default(DRAFT)
  scheduledAt  DateTime?
  payload      Json              @default("{}")
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  restaurant   Restaurant        @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@index([restaurantId, status])
  @@schema("public")
}

model Keyword {
  id               String      @id @default(cuid())
  restaurantId     String
  keyword          String
  ranking          Int?
  searchVolume     Int?
  opportunityScore Float?
  createdAt        DateTime    @default(now())
  restaurant       Restaurant  @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@index([restaurantId])
  @@schema("public")
}

model WebsiteEvent {
  id           String           @id @default(cuid())
  restaurantId String
  type         WebsiteEventType
  metadata     Json             @default("{}")
  createdAt    DateTime         @default(now())
  restaurant   Restaurant       @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@index([restaurantId])
  @@schema("public")
}

model DigestRun {
  id           String      @id @default(cuid())
  restaurantId String
  snapshot     Json       @default("{}")
  ranAt        DateTime   @default(now())
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@index([restaurantId, ranAt])
  @@schema("public")
}

model DemoRequest {
  id             String   @id @default(cuid())
  firstName      String
  lastName       String
  email          String
  restaurantName String
  addressLine1   String?
  city           String?
  postalCode     String?
  phone          String?
  message        String?
  createdAt      DateTime @default(now())

  @@index([createdAt])
  @@index([email])
  @@schema("public")
}

model DailyScan {
  id                String     @id @default(cuid())
  restaurantId      String
  scanDate          DateTime   @db.Date
  visibilityScore   Int?
  visualHealthScore Int?
  reviewHealthScore Int?
  briefingJson      Json       @default("{}")
  createdAt         DateTime   @default(now())
  restaurant        Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@unique([restaurantId, scanDate])
  @@index([restaurantId])
  @@schema("public")
}

model Asset {
  id           String     @id @default(cuid())
  restaurantId String
  type         AssetType
  url          String?
  metadata     Json       @default("{}")
  uploadedAt   DateTime   @default(now())
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@index([restaurantId, type])
  @@schema("public")
}

model CustomerReview {
  id                 String       @id @default(cuid())
  restaurantId      String
  source              ReviewSource
  externalReviewId    String?
  reviewerName        String?
  rating              Int
  body                String       @default("")
  reviewedAt          DateTime?
  replied             Boolean      @default(false)
  relationshipScore   Int          @default(0)
  restaurant          Restaurant   @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  replies             ReviewReply[]

  @@unique([source, externalReviewId])
  @@index([restaurantId, reviewedAt])
  @@schema("public")
}

model ReviewReply {
  id        String            @id @default(cuid())
  reviewId  String
  replyText String            @default("")
  status    ReviewReplyStatus @default(DRAFT)
  postedAt  DateTime?
  review    CustomerReview    @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@index([reviewId])
  @@schema("public")
}

model ReviewerProfile {
  id             String     @id @default(cuid())
  restaurantId String
  name           String
  contactInfo    Json       @default("{}")
  notes          String?
  totalVisits    Int        @default(0)
  influenceScore Int        @default(0)
  lastContactAt  DateTime?
  restaurant     Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@index([restaurantId])
  @@schema("public")
}

model AgentAction {
  id            String            @id @default(cuid())
  restaurantId String
  actionType    String
  description   String
  status        AgentActionStatus @default(PENDING)
  createdAt     DateTime          @default(now())
  restaurant    Restaurant        @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@index([restaurantId, createdAt])
  @@schema("public")
}

model OutboundLead {
  id                     String             @id @default(cuid())
  workspaceRestaurantId  String?
  placeId                String?
  city                   String?
  restaurantName         String?
  websiteUrl             String?
  contactEmail           String?
  insightSummary         String?
  messageSubject         String?
  messageBody            String?
  suggestedTone          String?
  status                 OutboundLeadStatus @default(DRAFT)
  source                 OutboundLeadSource @default(LEGACY)
  qualifyScore           Int?
  reviewCount            Int?
  enrichmentSource       String?
  createdAt              DateTime           @default(now())
  workspaceRestaurant    Restaurant?      @relation(fields: [workspaceRestaurantId], references: [id], onDelete: Cascade)

  @@index([status, createdAt])
  @@index([workspaceRestaurantId, status, createdAt])
  @@index([workspaceRestaurantId, source, status])
  @@index([placeId])
  @@schema("public")
}

model StripeWebhookEvent {
  id        String   @id
  type      String
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@schema("public")
}

/** Public visibility audit (grader funnel); no auth required to create. */
model VisibilityAudit {
  id                String    @id @default(cuid())
  restaurantId      String?
  restaurant        Restaurant? @relation(fields: [restaurantId], references: [id], onDelete: SetNull)
  restaurantName    String
  city              String
  websiteUrl        String?
  overallScore      Int
  seoScore          Int
  designScore       Int
  mobileScore       Int
  conversionScore   Int
  resultPayload     Json      @default("{}")
  leadEmail         String?
  leadPhone         String?
  leadCapturedAt    DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  siteScan          SiteScan?

  @@index([createdAt])
  @@index([restaurantId])
  @@schema("public")
}

/** Daily Chief of Staff brief + task queue for restaurant owners. */
model ChiefOfStaffTask {
  id                String        @id @default(cuid())
  restaurantId      String
  title             String
  detail            String        @default("")
  category          TaskCategory
  source            TaskSource
  status            TaskStatus    @default(PENDING)
  impactLabel       String?
  estimatedMinutes  Int           @default(5)
  confidenceScore   Int           @default(75)
  revenueLowGbp     Int?
  revenueHighGbp    Int?
  requiresIntegration String?
  draftPayload      Json?
  auditId           String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  restaurant        Restaurant    @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@index([restaurantId, status, createdAt])
  @@schema("public")
}

model DailyBriefSnapshot {
  id           String     @id @default(cuid())
  restaurantId String
  briefDate    DateTime   @db.Date
  greeting     String
  summaryJson  Json       @default("{}")
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@unique([restaurantId, briefDate])
  @@index([restaurantId])
  @@schema("public")
}

model SiteScan {
  id                   String          @id @default(cuid())
  visibilityAuditId    String          @unique
  visibilityAudit      VisibilityAudit @relation(fields: [visibilityAuditId], references: [id], onDelete: Cascade)
  browserbaseSessionId String?
  screenshotUrls       Json            @default("[]")
  rawStagehandJson     Json?
  visualMetricsJson    Json?
  status               String          @default("completed")
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
  @@schema("public")
}
