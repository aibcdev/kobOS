# =============================================================================
# KOB — TEMPLATE ONLY (no real secrets). Copy to ".env.local" and fill in values:
#   cp .env.example .env.local
#
# Prisma CLI does not load .env.local by default. Use:
#   npm run db:migrate
# which loads .env then .env.local (later wins). Or put DATABASE_URL in a root ".env" file.
# =============================================================================

# --- Database (Prisma + Next) ---
# Supabase → Settings → Database → Connection string → use "Session pooler" URI on IPv4 networks.
# Append ssl if needed, e.g. ?sslmode=require  (follow Supabase’s Prisma snippet)
DATABASE_URL=

# --- Supabase (auth + client) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Hosted Auth redirects: npm run setup:auth-urls (paste output into Supabase Dashboard)
# NETLIFY_PRODUCTION_URL=https://your-site.netlify.app

# --- Supabase CLI (optional; does NOT replace Prisma for schema) ---
# Login (browser): npm run supabase:login  →  link project: npm run supabase:link  (use project ref from dashboard URL)
# Types from linked remote: npm run supabase:types  → writes lib/supabase/database.types.ts
# Headless / CI: Account → Access Tokens → paste here, plus project ref (subdomain before .supabase.co)
# SUPABASE_ACCESS_TOKEN=
# SUPABASE_PROJECT_REF=
# Database password (dashboard). Used by: npm run supabase:sync-env → builds DATABASE_URL
# SUPABASE_DB_PASSWORD=

# --- Netlify CLI (optional) ---
# Login: npm run netlify:login  →  link site: netlify link  (from repo root)
# Deploy preview: npm run netlify:deploy
# CI (optional): NETLIFY_AUTH_TOKEN from Netlify user settings → Applications → Personal access tokens
# NETLIFY_AUTH_TOKEN=
# --- Production site (trykob.com) ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=https://trykob.com
NETLIFY_PRODUCTION_URL=https://trykob.com

# --- Gemini (all AI: chat, briefs, content, images, audits) ---
# Get key: https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
# Optional: image generation deployment (social posts with photos)
# GEMINI_IMAGE_MODEL=gemini-2.0-flash-preview-image-generation

# --- Stripe (optional) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Used by Stripe.js / Payment Element in the browser when you add client-side payments.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
# Optional: defaults to STRIPE_PRICE_STARTER for `/api/trial` + API trial helpers.
STRIPE_GROWTH_PRICE_ID=
# Subscription trial length (days) on Checkout when set (1–90).
STRIPE_TRIAL_DAYS=

# --- Browserbase (visibility audit — JS-rendered sites) ---
# https://browserbase.com — used when AUDIT_BROWSERBASE=1
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=
# 1 = force on; 0 = force off; unset = on when BROWSERBASE_* keys are set
# AUDIT_BROWSERBASE=1
# fallback | always (default when BROWSERBASE_* keys are set — recommended for Owner.com-grade scans)
# AUDIT_BROWSERBASE_MODE=always
# 1 = fetch scores first, then enrich via Inngest (recommended on short serverless timeouts)
AUDIT_BROWSERBASE_ASYNC=0
# 1 = use Browserbase managed proxies (may increase cost)
AUDIT_BROWSERBASE_PROXY=0

# --- Stagehand (optional LLM page extraction on Browserbase; costs tokens) ---
# Requires BROWSERBASE_* + an LLM key (GEMINI_API_KEY, ANTHROPIC_API_KEY, etc.).
# Owner.com crawl (free): npm run crawl:owner:free — paid render: npm run crawl:owner
# OWNER_CRAWL_MAX=30
AUDIT_STAGEHAND=0
# e.g. openai/gpt-4o-mini — see Stagehand model strings
AUDIT_STAGEHAND_MODEL=openai/gpt-4o-mini

# --- Audit screenshot heuristics (sharp stats on viewport PNG; set 0 to skip) ---
# AUDIT_VISUAL_METRICS=0

# --- Supabase Storage (optional public audit screenshots; service role bypasses RLS) ---
# Create bucket (e.g. kob-audit-screenshots) → public read or signed URLs per your policy.
# Login emails via Resend when Supabase SMTP fails (Dashboard → Settings → API → service_role)
# SUPABASE_SERVICE_ROLE_KEY=
# SUPABASE_AUDIT_BUCKET=kob-audit-screenshots

# --- Sales pipeline — see docs/SALES_PIPELINE.md ---
# OUTBOUND_MODE=uk_cold                       # UK cold pipeline (recommended for growth)
# OUTBOUND_UK_CITIES=London,Manchester,Birmingham,Leeds,Bristol,Glasgow,Edinburgh
# OUTBOUND_REVIEW_MIN=20
# OUTBOUND_REVIEW_MAX=500
# OUTBOUND_MAX_QUALIFY_SCORE=65
# OUTBOUND_UK_DAILY_CAP=20
# HUNTER_API_KEY=                             # email enrichment for UK cold (required)
# RESEND_API_KEY=
# RESEND_FROM_EMAIL=KOB <hello@trykob.com>
# RESEND_AUTH_FROM_EMAIL=KOB <hello@trykob.com>
# OUTBOUND_RESEND_NOTIFY_EMAIL=you@gmail.com
# OUTBOUND_WORKSPACE_RESTAURANT_ID=
# OUTBOUND_SCAN_CITY=London                   # legacy mode only
# OUTBOUND_SALES_MODE=1
# PLACES_AUTOCOMPLETE_REGIONS=GB
# CRON_SECRET=

# --- Audit funnel rate limits (per IP, in-process; disable for local dev if needed) ---
AUDIT_RATE_LIMIT_MAX_REQUESTS=30
AUDIT_RATE_LIMIT_WINDOW_SEC=3600
# AUDIT_RATE_LIMIT_DISABLED=1

# --- PageSpeed Insights (factual mobile performance in audit rubric) ---
# Uses PAGESPEED_API_KEY, or GOOGLE_PAGESPEED_API_KEY, or falls back to GEMINI_API_KEY if enabled for Google APIs.
# PAGESPEED_API_KEY=

# --- Google Maps Platform (audit search + scanning UI) ---
# Cloud Console → enable billing → enable "Places API (New)" + "Maps JavaScript API".
# Server-only key for Places REST (Autocomplete + Place Details). Restrict by IP on servers, or use a
# separate browser-restricted key only if you must call Places from the client (we proxy via /api/places/*).
GOOGLE_PLACES_API_KEY=
# Browser key for embedded map on /audit/[id]/scanning. Restrict by HTTP referrer (localhost, ngrok, prod).
# If unset, scanning falls back to /api/places/static-map using GOOGLE_PLACES_API_KEY.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
# Optional: tighten Places autocomplete (comma-separated ISO region codes, e.g. US,GB).
# PLACES_AUTOCOMPLETE_REGIONS=US,GB

# --- Sanity CMS (optional) ---
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2026-02-01

# --- Integrations / misc ---
INTEGRATION_ENC_KEY=

# --- Growth toggles (optional) ---
GROWTH_AUTO_AI_RECOMMENDATIONS=
GROWTH_SEED_DEMO=
OUTBOUND_SCAN_CITY=
OUTBOUND_WORKSPACE_RESTAURANT_ID=
# Max approved outbound emails per Inngest send run (default 25, cap 25).
# OUTBOUND_SEND_BATCH=25

# --- Preview / dev only ---
NEXT_PUBLIC_UI_PREVIEW=
# 1 = auto-load Growth Agent daily briefing on Today (OpenAI cost on each visit)
# NEXT_PUBLIC_DASHBOARD_AUTO_BRIEFING=1

# --- Inngest (background audit jobs) ---
# Full audit locally (site + Inngest worker): npm run dev:audit
# Requires: DATABASE_URL, INNGEST_DEV=1, GEMINI_API_KEY (benchmark + images), GOOGLE_PLACES_API_KEY (location/competitors)
# Optional: NEXT_PUBLIC_GOOGLE_MAPS_API_KEY (live scanning map; static map fallback uses server key)
# Local: npm run dev:public + npm run inngest:dev (requires INNGEST_DEV=1)
# Production: https://app.inngest.com → sync https://YOUR-SITE.netlify.app/api/inngest
INNGEST_DEV=1
INNGEST_SIGNING_KEY=
INNGEST_EVENT_KEY=
