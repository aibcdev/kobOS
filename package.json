{
  "name": "kob",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:public": "dotenv -e .env -e .env.local -- next dev -p 3000",
    "dev:public:reset": "node scripts/kill-port.mjs 3000 && npm run dev:public",
    "dev:audit": "node scripts/dev-audit.mjs",
    "ngrok": "ngrok http 3000",
    "dev:kob": "next dev --port 3333",
    "dev:kob:reset": "node -e \"try{require('fs').unlinkSync('.next/dev/lock')}catch(e){}\" && next dev --port 3333",
    "dev:local": "next dev --port 3004",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "postinstall": "prisma generate",
    "db:migrate": "dotenv -e .env -e .env.local -- prisma migrate deploy",
    "db:setup": "dotenv -e .env -e .env.local -- prisma db push",
    "db:doctor": "node scripts/db-doctor.mjs",
    "db:push": "dotenv -e .env -e .env.local -- prisma db push",
    "netlify": "netlify",
    "netlify:dev": "netlify dev",
    "netlify:deploy": "netlify deploy --build",
    "netlify:login": "netlify login",
    "netlify:status": "netlify status",
    "supabase": "supabase",
    "supabase:start": "supabase start",
    "supabase:stop": "supabase stop",
    "supabase:types": "supabase gen types typescript --linked --schema public > lib/supabase/database.types.ts",
    "supabase:link": "supabase link",
    "supabase:sync-env": "node scripts/sync-supabase-env-from-cli.mjs",
    "supabase:login": "supabase login",
    "inngest:dev": "dotenv -e .env -e .env.local -- inngest dev -u http://localhost:3000/api/inngest",
    "dev:check": "node scripts/dev-check.mjs",
    "crawl:owner": "dotenv -e .env -e .env.local -- npx tsx scripts/crawl-owner-com.ts",
    "crawl:owner:free": "dotenv -e .env -e .env.local -- npx tsx scripts/crawl-owner-com-free.ts",
    "marketing:check-owner": "node scripts/marketing-check-owner-copy.mjs",
    "setup:auth-urls": "node scripts/print-supabase-auth-config.mjs",
    "smoke:check": "node scripts/smoke-check.mjs"
  },
  "dependencies": {
    "@browserbasehq/sdk": "^2.11.0",
    "@browserbasehq/stagehand": "^3.4.0",
    "@google/generative-ai": "^0.24.1",
    "@googlemaps/js-api-loader": "^2.0.2",
    "@prisma/client": "6.19.3",
    "@sanity/icons": "^3.7.4",
    "@sanity/image-url": "^2.1.1",
    "@sanity/vision": "^5.24.0",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.105.4",
    "framer-motion": "^12.38.0",
    "iconify-icon": "^3.0.2",
    "inngest": "^4.3.0",
    "next": "16.2.6",
    "next-sanity": "^12.4.5",
    "openai": "^6.37.0",
    "playwright-core": "^1.60.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "resend": "^6.12.3",
    "sanity": "^5.24.0",
    "sharp": "^0.34.5",
    "stripe": "^17.7.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/google.maps": "^3.64.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv-cli": "^8.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "inngest-cli": "^1.19.3",
    "netlify-cli": "^23.12.3",
    "prisma": "6.19.3",
    "supabase": "^2.98.2",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^3.2.4"
  }
}
